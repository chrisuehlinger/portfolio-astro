---
import Nav from '@/components/Nav.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found | Chris Uehlinger">
  <Nav />
  <main class="section not-found">
    <h1>404</h1>
  </main>
</BaseLayout>

<style>
  .not-found {
    align-items: center;
    display: flex;
    min-height: 80vh;
  }

  h1 {
    font-size: clamp(3rem, 12vw, 9rem);
    font-weight: 400;
    letter-spacing: 0;
    margin: 0;
  }
</style>
