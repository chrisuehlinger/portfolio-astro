---
import MediaRenderer from '@/components/MediaRenderer.astro';
import Nav from '@/components/Nav.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatShowDate, getPortfolioData, sortFeaturedShows } from '@/lib/content';
import { renderMarkdown } from '@/lib/markdown';

export async function getStaticPaths() {
  const data = await getPortfolioData();

  return sortFeaturedShows(data.shows).map((show) => ({
    params: { slug: show.slug },
    props: { show },
  }));
}

const { show } = Astro.props;
const blurb = await renderMarkdown(show.blurbMarkdown);
const caseStudy = show.caseStudyMarkdown ? await renderMarkdown(show.caseStudyMarkdown) : '';
---

<BaseLayout
  title={show.seo?.title ?? `${show.title} | Chris Uehlinger`}
  description={show.seo?.description}
  image={show.seo?.socialImage ?? show.tileImage?.url}
>
  <Nav />
  <main class="show-page">
    <header class="show-header">
      <a class="back-link" href="/">Work</a>
      <h1>{show.title}</h1>
      <dl>
        <div>
          <dt>Company</dt>
          <dd>{show.companies.join(', ')}</dd>
        </div>
        <div>
          <dt>Director</dt>
          <dd>{show.directors.join(', ')}</dd>
        </div>
        <div>
          <dt>Date</dt>
          <dd>{formatShowDate(show.showDate)}</dd>
        </div>
        <div>
          <dt>Role</dt>
          <dd>{show.roles.map((role) => <span>{role}</span>)}</dd>
        </div>
      </dl>
    </header>

    <section class="section">
      <div class="markdown" set:html={blurb} />
    </section>

    {
      show.media.length > 0 && (
        <section class="section media-list" aria-label="Show media">
          {show.media.map((item) => <MediaRenderer item={item} />)}
        </section>
      )
    }

    {
      caseStudy && (
        <section class="section">
          <div class="markdown" set:html={caseStudy} />
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .show-page {
    padding-top: 3rem;
  }

  .show-header {
    margin: 0 auto;
    max-width: 1280px;
    padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1rem, 3vw, 2rem) clamp(1rem, 2.5vw, 2rem);
  }

  .back-link {
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.2rem, 8vw, 6.5rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.95;
    margin: 1rem 0 1.4rem;
    max-width: 12ch;
  }

  dl {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 0;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0;
  }

  dl > div {
    border-bottom: 1px solid var(--line);
    padding: 0.9rem 1rem 0.9rem 0;
  }

  dt {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  dd {
    line-height: 1.4;
    margin: 0;
  }

  dd span {
    display: block;
  }

  .media-list {
    max-width: 960px;
  }

  .section {
    padding-block: clamp(1.25rem, 3vw, 2.75rem);
  }

  .section:first-of-type {
    padding-bottom: clamp(1rem, 2vw, 2rem);
  }

  .section + .section {
    padding-top: clamp(0.75rem, 2vw, 1.5rem);
  }

  @media (max-width: 760px) {
    dl {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
